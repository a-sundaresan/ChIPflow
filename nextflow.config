// ============================================================
// ChIP-seq Pipeline - nextflow.config
// ============================================================
// Containers: Singularity .sif files pulled by pull_containers.sh
// Set CONTAINER_DIR to the directory where you ran that script.
//
// To use Docker instead, replace each `container = "..."` line
// with the docker:// URI shown in the comment above it, and set:
//   docker.enabled  = true
//   singularity.enabled = false
// ============================================================

singularity.enabled    = true
singularity.autoMounts = true

// Set this to the directory where pull_containers.sh saved the .sif files
CONTAINER_DIR = "${projectDir}/containers"

process {
    withName: FastQC {
        // docker://quay.io/biocontainers/fastqc:0.12.1--hdfd78af_0
        container = "${CONTAINER_DIR}/fastqc-0.12.1.sif"
    }
}

process {
    withName: FASTP {
        cpus   = 4
        memory = '8 GB'
        // docker://quay.io/biocontainers/fastp:0.24.0--heae3180_1
        container = "${CONTAINER_DIR}/fastp-0.24.0.sif"
    }
}

process {
    withName: STAR_ALIGN {
        cpus   = 8
        memory = '32 GB'
        // docker://quay.io/biocontainers/star:2.7.10b--h9ee0642_0
        container = "${CONTAINER_DIR}/star-2.7.10b.sif"
    }
}

process {
    withName: BOWTIE2_ALIGN {
        cpus   = 8
        memory = '16 GB'
        // docker://quay.io/biocontainers/bowtie2:2.5.2--py39h6fed5c7_0
        container = "${CONTAINER_DIR}/bowtie2-2.5.2.sif"
    }
}

process {
    withName: SAMTOOLS_SORT_INDEX {
        cpus   = 8
        memory = '16 GB'
        // docker://quay.io/biocontainers/samtools:1.21--h50ea8bc_0
        container = "${CONTAINER_DIR}/samtools-1.21.sif"
    }
}

process {
    withName: PICARD_MARKDUPLICATES {
        cpus   = 8
        memory = '16 GB'
        // docker://quay.io/biocontainers/picard:3.3.0--hdfd78af_0
        container = "${CONTAINER_DIR}/picard-3.3.0.sif"
    }
}

process {
    withName: SAMTOOLS_REMOVE_DUPLICATES {
        cpus   = 8
        memory = '16 GB'
        // docker://quay.io/biocontainers/samtools:1.21--h50ea8bc_0
        container = "${CONTAINER_DIR}/samtools-1.21.sif"
    }
}

process {
    withName: FILTER_ENCODE {
        cpus   = 8
        memory = '16 GB'
        // docker://quay.io/biocontainers/bedtools:2.31.1--hf5e1c6e_2
        container = "${CONTAINER_DIR}/bedtools-2.31.1.sif"
    }
}

process {
    withName: SAMTOOLS_SORT_INDEX_POST_ENCODE_FILTER {
        cpus   = 8
        memory = '16 GB'
        // docker://quay.io/biocontainers/samtools:1.21--h50ea8bc_0
        container = "${CONTAINER_DIR}/samtools-1.21.sif"
    }
}

process {
    withName: GENERATE_BEDGRAPH {
        cpus   = 8
        memory = '16 GB'
        // docker://quay.io/biocontainers/bedtools:2.31.1--hf5e1c6e_2
        container = "${CONTAINER_DIR}/bedtools-2.31.1.sif"
    }
}

process {
    withName: GENERATE_BIGWIG {
        cpus   = 8
        memory = '16 GB'
        // docker://quay.io/biocontainers/ucsc-bedgraphtobigwig:469--h9b8f530_0
        container = "${CONTAINER_DIR}/ucsc-bedgraphtobigwig-469.sif"
    }
}

process {
    withName: PLOT_FINGERPRINT {
        cpus   = 8
        memory = '16 GB'
        // docker://quay.io/biocontainers/deeptools:3.5.1--py_0
        container = "${CONTAINER_DIR}/deeptools-3.5.1.sif"
    }
}

process {
    withName: CALL_PEAKS {
        cpus   = 8
        memory = '16 GB'
        // docker://quay.io/biocontainers/macs2:2.2.7.1--py38h4a8c8d9_3
        container = "${CONTAINER_DIR}/macs2-2.2.7.1.sif"
    }
}

process {
    withName: ANNOTATE_PEAKS {
        cpus   = 8
        memory = '16 GB'
        // docker://quay.io/biocontainers/homer:4.11--pl5262h4ac6f70_9
        container = "${CONTAINER_DIR}/homer-4.11.sif"
    }
}

process {
    withName: PEAK_MOTIF {
        cpus   = 8
        memory = '16 GB'
        // docker://quay.io/biocontainers/homer:4.11--pl5262h4ac6f70_9
        container = "${CONTAINER_DIR}/homer-4.11.sif"
    }
}

process {
    withName: MULTIQC {
        cpus   = 4
        memory = '8 GB'
        // docker://quay.io/biocontainers/multiqc:1.21--pyhdfd78af_0
        container = "${CONTAINER_DIR}/multiqc-1.21.sif"
    }
}

// ============================================================
// Pipeline parameters — update paths for your environment
// ============================================================
params {
    csv              = "samplesheet.csv"
    outdir           = "results"
    fail_on_missing  = true
    aligner          = 'star'            // 'star' or 'bowtie2'

    // --- Reference genome (GRCh38 / hg38 example) -----------
    STAR_genomeDir   = "/path/to/STAR_index"
    bowtie2_index    = "/path/to/bowtie2_index/genome"
    fasta            = "/path/to/genome.fasta"
    gtf              = "/path/to/annotation.gtf"
    encode_blacklist = "/path/to/hg38-blacklist.v2.bed"
    chrom_size       = "/path/to/chrom.sizes"

    // --- MACS2 effective genome size ------------------------
    // Use 'hs' for human (GRCh38), 'mm' for mouse (GRCm38/mm10)
    macs2_genome_size = 'hs'
}
