// ============================================================
// ChIP-seq Pipeline - nextflow.config
// ============================================================
// Containers: Singularity images are specified below.
// Docker URIs are provided as comments — swap the container
// lines if running in a Docker environment.
// ============================================================

singularity.enabled    = true
singularity.autoMounts = true

process {
    withName: FastQC {
        // container = 'docker://quay.io/biocontainers/fastqc:0.12.1--hdfd78af_0'
        container = '/path/to/singularity/singularity-fastqc-0.12.1--hdfd78af_0.img'
    }
}

process {
    withName: FASTP {
        cpus   = 4
        memory = '8 GB'
        // container = 'docker://quay.io/biocontainers/fastp:0.24.0--heae3180_1'
        container = '/path/to/singularity/fastp-0.24.0.img'
    }
}

process {
    withName: STAR_ALIGN {
        cpus   = 8
        memory = '32 GB'
        // container = 'docker://quay.io/biocontainers/star:2.7.10b--h9ee0642_0'
        container = '/path/to/singularity/singularity-star-2.7.10b--h9ee0642_0.img'
    }
}

process {
    withName: BOWTIE2_ALIGN {
        cpus   = 8
        memory = '16 GB'
        // container = 'docker://quay.io/biocontainers/bowtie2:2.5.2--py39h6fed5c7_0'
        container = '/path/to/singularity/singularity-bowtie2-2.5.2--py39h6fed5c7_0.img'
    }
}

process {
    withName: SAMTOOLS_SORT_INDEX {
        cpus   = 8
        memory = '16 GB'
        // container = 'docker://quay.io/biocontainers/samtools:1.21--h50ea8bc_0'
        container = '/path/to/singularity/singularity-samtools-1.21--h50ea8bc_0.img'
    }
}

process {
    withName: PICARD_MARKDUPLICATES {
        cpus   = 8
        memory = '16 GB'
        // container = 'docker://quay.io/biocontainers/picard:3.3.0--hdfd78af_0'
        container = '/path/to/singularity/picard-3.3.0.img'
    }
}

process {
    withName: SAMTOOLS_REMOVE_DUPLICATES {
        cpus   = 8
        memory = '16 GB'
        // container = 'docker://quay.io/biocontainers/samtools:1.21--h50ea8bc_0'
        container = '/path/to/singularity/singularity-samtools-1.21--h50ea8bc_0.img'
    }
}

process {
    withName: FILTER_ENCODE {
        cpus   = 8
        memory = '16 GB'
        // container = 'docker://quay.io/biocontainers/bedtools:2.31.1--hf5e1c6e_2'
        container = '/path/to/singularity/bedtools-2.31.1.img'
    }
}

process {
    withName: SAMTOOLS_SORT_INDEX_POST_ENCODE_FILTER {
        cpus   = 8
        memory = '16 GB'
        // container = 'docker://quay.io/biocontainers/samtools:1.21--h50ea8bc_0'
        container = '/path/to/singularity/singularity-samtools-1.21--h50ea8bc_0.img'
    }
}

process {
    withName: GENERATE_BEDGRAPH {
        cpus   = 8
        memory = '16 GB'
        // container = 'docker://quay.io/biocontainers/bedtools:2.31.1--hf5e1c6e_2'
        container = '/path/to/singularity/bedtools-2.31.1.img'
    }
}

process {
    withName: GENERATE_BIGWIG {
        cpus   = 8
        memory = '16 GB'
        // container = 'docker://quay.io/biocontainers/ucsc-bedgraphtobigwig:469--h9b8f530_0'
        container = '/path/to/singularity/singularity-ucsc-bedgraphtobigwig-469--h9b8f530_0.img'
    }
}

process {
    withName: PLOT_FINGERPRINT {
        cpus   = 8
        memory = '16 GB'
        // container = 'docker://quay.io/biocontainers/deeptools:3.5.1--py_0'
        container = '/path/to/singularity/deeptools-3.5.1.img'
    }
}

process {
    withName: CALL_PEAKS {
        cpus   = 8
        memory = '16 GB'
        // container = 'docker://quay.io/biocontainers/macs2:2.2.7.1--py38h4a8c8d9_3'
        container = '/path/to/singularity/macs2-2.2.7.1.img'
    }
}

process {
    withName: ANNOTATE_PEAKS {
        cpus   = 8
        memory = '16 GB'
        // container = 'docker://quay.io/biocontainers/homer:4.11--pl5262h4ac6f70_9'
        container = '/path/to/singularity/homer-4.11.img'
    }
}

process {
    withName: PEAK_MOTIF {
        cpus   = 8
        memory = '16 GB'
        // container = 'docker://quay.io/biocontainers/homer:4.11--pl5262h4ac6f70_9'
        container = '/path/to/singularity/homer-4.11.img'
    }
}

process {
    withName: MULTIQC {
        cpus   = 4
        memory = '8 GB'
        // container = 'docker://quay.io/biocontainers/multiqc:1.21--pyhdfd78af_0'
        container = '/path/to/singularity/multiqc-1.21.img'
    }
}

// ============================================================
// Pipeline parameters — update paths for your environment
// ============================================================
params {
    csv              = "samplesheet.csv"
    outdir           = "results"
    fail_on_missing  = true
    aligner          = 'star'            // 'star' or 'bowtie2'

    // --- Reference genome (GRCh38 / hg38 example) -----------
    STAR_genomeDir   = "/path/to/STAR_index"
    bowtie2_index    = "/path/to/bowtie2_index/genome"
    fasta            = "/path/to/genome.fasta"
    gtf              = "/path/to/annotation.gtf"
    encode_blacklist = "/path/to/hg38-blacklist.v2.bed"
    chrom_size       = "/path/to/chrom.sizes"

    // --- MACS2 effective genome size ------------------------
    // Use 'hs' for human (GRCh38), 'mm' for mouse (GRCm38/mm10)
    macs2_genome_size = 'hs'
}
